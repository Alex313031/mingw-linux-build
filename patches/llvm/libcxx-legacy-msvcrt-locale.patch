+// On the legacy msvcrt.dll (NT 4.0/2000/XP target: non-UCRT, __MSVCRT_VERSION__
+// < 0x0800) the per-locale "_l" helpers are unavailable. Some are not even
+// declared by mingw (compile errors); others (e.g. _mbtowc_l, _strtod_l) link as
+// msvcrt.dll imports that the legacy system DLL does not export, so a C++ program
+// fails to LOAD on pre-Vista. Route them through a thread-locale guard around the
+// plain functions instead; mingw-w64 supplies _configthreadlocale().
+#if defined(__MINGW32__) && !defined(_UCRT) && (!defined(__MSVCRT_VERSION__) || __MSVCRT_VERSION__ < 0x0800)
+#  define _LIBCPP_LEGACY_MSVCRT_LOCALE 1
+#endif
+
+// __locale_guard, relocated here from the bottom of the file. Defined for the
+// libc++ build (its original users) AND for legacy msvcrt (our new users) -- some
+// of which (the strtonum helpers) live outside _LIBCPP_BUILDING_LIBRARY, so the
+// guard must have a single consistent definition across the library and user TUs
+// (no ODR mismatch). It calls ::setlocale directly rather than the library-only
+// __locale::__setlocale wrapper.
+#if defined(_LIBCPP_BUILDING_LIBRARY) || defined(_LIBCPP_LEGACY_MSVCRT_LOCALE)
+struct __locale_guard {
+  _LIBCPP_HIDE_FROM_ABI __locale_guard(__locale_t __l) : __status(_configthreadlocale(_ENABLE_PER_THREAD_LOCALE)) {
+    // Setting the locale can be expensive even when the locale given is already
+    // the current locale, so check first.
+    const char* __lc = ::setlocale(LC_ALL, nullptr);
+    if (__lc != nullptr && ::strcmp(__l.__get_locale(), __lc) != 0) {
+      __locale_all = _strdup(__lc);
+      if (__locale_all == nullptr)
+        std::__throw_bad_alloc();
+      ::setlocale(LC_ALL, __l.__get_locale());
+    }
+  }
+  _LIBCPP_HIDE_FROM_ABI ~__locale_guard() {
+    if (__locale_all != nullptr) {
+      ::setlocale(LC_ALL, __locale_all);
+      free(__locale_all);
+    }
+    _configthreadlocale(__status);
+  }
+  int __status;
+  char* __locale_all = nullptr;
+};
+#endif
